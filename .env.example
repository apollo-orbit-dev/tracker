# Tracker — environment variables
# Copy this file to .env and fill in real values. Never commit .env.

# --- Database ---
# PostgreSQL connection string used by the FastAPI backend and Alembic migrations.
DATABASE_URL=postgresql+psycopg://tracker:changeme@localhost:5432/tracker

# Connection string for the test database. The pytest session-scoped fixture
# drops and recreates this database, then runs migrations against it.
TEST_DATABASE_URL=postgresql+psycopg://tracker:changeme@localhost:5432/tracker_test

# --- Session signing ---
# Secret used to sign session cookies. Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
# Rotating this value invalidates all active sessions.
SESSION_SECRET=changeme

# --- App config ---
# Environment name. One of: development, staging, production.
APP_ENV=development

# Logging verbosity. One of: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# Comma-separated allowlist for CSRF Origin/Referer check on unsafe API
# requests. Match the URL(s) the frontend is served from.
ALLOWED_ORIGINS=http://localhost:5181

# --- Bootstrap admin (only used on first run when no users exist) ---
# Email and password for the initial admin account, created by the seed script.
# Change immediately after first login.
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=changeme

# --- Vite dev server (frontend) ---
# Comma-separated allowlist for Vite's Host-header filter. Set when
# accessing the frontend behind a reverse proxy at a custom hostname
# (e.g. tracker.lan,demo.example.com). Leave blank to allow any host
# — fine for LAN demos; tighten when exposed past trusted networks.
VITE_ALLOWED_HOSTS=

# --- Postgres credentials (used by the docker-compose stacks) ---
# Both the dev and the production composes read these. The dev compose
# defaults to tracker/changeme/tracker if unset; the prod compose
# requires POSTGRES_PASSWORD to be set explicitly (refuses to start
# without it).
POSTGRES_USER=tracker
POSTGRES_PASSWORD=changeme
POSTGRES_DB=tracker

# --- Production-only ---
# Host port Caddy publishes the stack on. Used by docker-compose.prod.yml
# only. Default 8080. Behind a TLS-terminating reverse proxy, point that
# proxy at this port.
HOST_PORT=8080
